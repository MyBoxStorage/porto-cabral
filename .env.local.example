# ─── Supabase (autenticação de clientes e admins) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL_PC=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PC=
SUPABASE_SERVICE_ROLE_KEY_PC=

# ─── NextAuth v5 (prefixo PC_ para evitar conflito com outras apps na Vercel) ──
PC_NEXTAUTH_SECRET=             # openssl rand -base64 32
PC_NEXTAUTH_URL=http://localhost:3000

# ─── Resend (e-mails transacionais) ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=reservas@portocabralbc.com.br

# ─── Google Places API (reviews) ────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ─── BC Connect Integration ──────────────────────────────────────────────────
BC_CONNECT_WEBHOOK_URL=https://bc-connect-api-v2.fly.dev
BC_CONNECT_API_KEY=
BC_CONNECT_PARTNER_ID=
NEXT_PUBLIC_BC_CONNECT_WIDGET_KEY=   # opcional — desativado por padrão

# ─── Payload CMS ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=                 # openssl rand -base64 32  (OBRIGATÓRIO — app não sobe sem)
PC_DATABASE_URL=                # postgresql://user:pass@host:5432/db
# Chave dedicada para POST /api/admin/sync-menu via hook interno do Payload.
# Deve ser DIFERENTE de PAYLOAD_SECRET para limitar escopo de comprometimento.
SYNC_MENU_SECRET=               # openssl rand -base64 24

# ─── Admins ──────────────────────────────────────────────────────────────────
ADMIN_EMAILS=                   # e-mails separados por vírgula, case-insensitive

# ─── Site (URL pública — usada em metadata, sitemap, OG image e Payload) ────
NEXT_PUBLIC_PC_SITE_URL=http://localhost:3000

# ─── Upstash Redis (rate limiting nas APIs públicas) ─────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry (monitoramento de erros em produção) ─────────────────────────────
SENTRY_ORG=                     # slug da organização no sentry.io
SENTRY_PROJECT=                 # slug do projeto no sentry.io
NEXT_PUBLIC_SENTRY_DSN=         # DSN do projeto (começa com https://...)
